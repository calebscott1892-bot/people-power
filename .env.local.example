# Frontend-only Vite env. Copy to .env.local for local development.
# Do not put service-role keys or other backend secrets in VITE_* variables.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-key>

# Backend origin used by frontend REST and WebSocket clients.
VITE_API_BASE_URL=http://127.0.0.1:3001
VITE_BACKEND_BASE=http://127.0.0.1:3001

# Canonical site URL used for Supabase auth redirects.
# Must match the Site URL and Redirect URLs configured in Supabase.
VITE_SITE_URL=http://127.0.0.1:5173

# Optional diagnostics, only for local/admin debugging.
# VITE_ENABLE_DIAG_ENDPOINT=false
# VITE_ADMIN_EMAILS=admin@example.com
