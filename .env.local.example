# Backend base URL for frontend API calls (single source of truth)
# If unset, the app defaults to:
# - http://localhost:3001 when the SPA is served from localhost/127.0.0.1
# - https://people-power.onrender.com otherwise
# VITE_API_BASE_URL=http://localhost:3001
# VITE_API_BASE_URL=https://people-power.onrender.com

# App-owned client base (optional; "relative" uses same-origin URLs like "/api/..." via Vite proxy)
# VITE_APP_API_BASE_URL=relative
