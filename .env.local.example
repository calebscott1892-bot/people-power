# FRONTEND ONLY: Vite envs (never commit secrets)
# Copy to .env.local for local development (do not commit .env.local).

# Supabase (frontend auth)
VITE_SUPABASE_URL=https://<your-supabase-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Backend base URL for frontend API calls (optional; overrides defaults)
# VITE_API_BASE_URL=https://people-power.onrender.com

# App-owned client base (optional; "relative" uses same-origin URLs like "/api/..." via Vite proxy)
# VITE_APP_API_BASE_URL=relative
