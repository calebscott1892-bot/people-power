{
  "appId": "app.peoplepower.mobile",
  "appName": "People Power",
  "webDir": "dist",
  "ios": {
    "contentInset": "automatic",
    "scheme": "People Power",
    "backgroundColor": "#0f172a"
  },
  "android": {
    "backgroundColor": "#0f172a"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "splashFullScreen": true,
      "splashImmersive": true,
      "backgroundColor": "#0f172a",
      "launchShowDuration": 2000
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f172a"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  }
}
